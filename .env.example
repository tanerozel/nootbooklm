# ── LLM provider ────────────────────────────────────────────────────────────
# Supported: openai | anthropic
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Embedding ────────────────────────────────────────────────────────────────
# Supported: openai | huggingface
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
# For HuggingFace local model:
# EMBEDDING_PROVIDER=huggingface
# EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
# EMBEDDING_DIMENSION=768

# ── OpenSearch ───────────────────────────────────────────────────────────────
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin
OPENSEARCH_INDEX=nootbooklm_chunks
OPENSEARCH_USE_SEARCH_PIPELINE=true
OPENSEARCH_SEARCH_PIPELINE=nootbooklm_hybrid_pipeline

# ── Retrieval / Rerank ─────────────────────────────────────────────────────────
RERANKER_ENABLED=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_K=8

# ── Backend ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-at-least-32-chars
BACKEND_CORS_ORIGINS=http://localhost:3000

# ── Auth ─────────────────────────────────────────────────────────────────────
# Set a non-empty value to require an API key on all protected endpoints.
# Clients must send:  Authorization: ******
# Leave blank to disable authentication (development / trusted networks).
API_KEY=

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Maximum requests per minute per IP address. Set to 0 to disable.
RATE_LIMIT_RPM=60

# ── Cost control ─────────────────────────────────────────────────────────────
# Maximum LLM tokens consumed per day (UTC). 0 = unlimited.
MAX_TOKENS_PER_DAY=0

# ── Chunking ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=400
CHUNK_OVERLAP=50
